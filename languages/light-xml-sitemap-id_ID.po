#: admin/class-light-xml-sitemap-admin.php:74
msgid "Light-XML Sitemap"
msgstr "Light-XML Sitemap"

#: admin/class-light-xml-sitemap-admin.php:86
msgid "Settings"
msgstr "Pengaturan"

#: admin/partials/light-xml-sitemap-admin-options.php:4
msgid "Your settings have been successfully updated."
msgstr "Pengaturan Anda berhasil diperbarui."

#: admin/partials/light-xml-sitemap-admin-options.php:33
msgid "Include Posts"
msgstr "Sertakan Postingan"

#: admin/partials/light-xml-sitemap-admin-options.php:41
#: admin/partials/light-xml-sitemap-admin-options.php:53
msgid "Do you want to include the posts into the sitemap."
msgstr "Apakah Anda ingin menyertakan postingan ke dalam peta situs."

#: admin/partials/light-xml-sitemap-admin-options.php:45
msgid "Include Custom Post Types"
msgstr "Sertakan Tipe Postingan Kustom"

#: admin/partials/light-xml-sitemap-admin-options.php:64
msgid "Include %s."
msgstr "Sertakan %s."

#: admin/partials/light-xml-sitemap-admin-options.php:72
#: admin/partials/light-xml-sitemap-admin-options.php:88
msgid "Do you want to include the pages into the sitemap."
msgstr "Apakah Anda ingin menyertakan halaman ke dalam peta situs."

#: admin/partials/light-xml-sitemap-admin-options.php:80
msgid "Include Pages"
msgstr "Sertakan Halaman"

#: admin/partials/light-xml-sitemap-admin-options.php:92
msgid "Include Categories"
msgstr "Sertakan Kategori"

#: admin/partials/light-xml-sitemap-admin-options.php:100
msgid "Do you want to include the categories into the sitemap."
msgstr "Apakah Anda ingin menyertakan kategori ke dalam peta situs."

#: admin/partials/light-xml-sitemap-admin-options.php:104
msgid "Include Tags"
msgstr "Sertakan Tag"

#: admin/partials/light-xml-sitemap-admin-options.php:112
msgid "Do you want to include the tags into the sitemap."
msgstr "Apakah Anda ingin menyertakan tag ke dalam peta situs."

#: admin/partials/light-xml-sitemap-admin-options.php:116
msgid "Include Author"
msgstr "Sertakan Penulis"

#: admin/partials/light-xml-sitemap-admin-options.php:124
msgid "Do you want to include the authors into the sitemap."
msgstr "Apakah Anda ingin menyertakan penulis ke dalam peta situs."

#: admin/partials/light-xml-sitemap-admin-options.php:128
msgid "Sitemap Name"
msgstr "Nama Peta Situs"

#: admin/partials/light-xml-sitemap-admin-options.php:129
msgid "Enter the sitemap name"
msgstr "Masukkan nama peta situs"

#: admin/partials/light-xml-sitemap-admin-options.php:130
msgid "Set an alternative name for the sitemap index (Leave empty to use the default: sitemap.xml)."
msgstr "Tetapkan nama alternatif untuk indeks peta situs (Kosongkan untuk menggunakan default: sitemap.xml)."

#: admin/partials/light-xml-sitemap-admin-options.php:133
msgid "Update Settings"
msgstr "Perbarui Pengaturan"

